{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run LEDCountDown",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"src\\LEDCountDown.csproj"
			],
			"group": "build"
		},
		{
			"label": "Build LEDCountDown",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"src\\LEDCountDown.csproj"
			],
			"group": "build"
		},
		{
			"label": "Build LEDCountDown (Release)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"-c",
				"Release",
				"src\\LEDCountDown.csproj"
			],
			"group": "build"
		}
	]
}